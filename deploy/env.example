# OpenClaw Monitor 环境变量配置
# 复制此文件到 /opt/openclaw-monitor/.env 并修改

# JWT 签名密钥（必须固定，否则每次重启后旧 Token 失效）
SECRET_KEY=your-secret-key-here

# Collector API Key（采集器心跳认证）
COLLECTOR_API_KEY=your-collector-api-key-here

# 可选配置
# SERVER_PORT=9200
# HEARTBEAT_TIMEOUT=180
# STATUS_CHECK_INTERVAL=30
# ACCESS_TOKEN_EXPIRE_HOURS=24
# DATABASE_URL=sqlite+aiosqlite:///server/monitor.db
